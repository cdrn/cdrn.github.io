---
layout: layouts/base.njk
---
{# Syntax highlighting — light theme by default, dark Okaidia under data-theme="dark" via CSS nesting #}
{%- css %}{% include "node_modules/prismjs/themes/prism.css" %}{% endcss %}
{%- css %}
[data-theme="dark"] {
{% include "node_modules/prismjs/themes/prism-okaidia.css" %}
}
{% endcss %}
{%- css %}{% include "public/css/prism-diff.css" %}{%- endcss %}
<h1>{{ title }}</h1>

{%- set minutes = content | readingTime -%}
<ul class="post-metadata">
	<li><time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time><span class="post-reading-time">{{ minutes }} min read</span></li>
	{%- for tag in tags | filterTagList %}
	{%- set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
	<li><a href="{{ tagUrl }}" class="post-tag">{{ tag }}</a>{%- if not loop.last %},{% endif %}</li>
	{%- endfor %}
</ul>

{%- if minutes >= 10 %}
{{ content | toc | safe }}
{%- endif %}

{{ content | safe }}

{%- if collections.posts %}
{%- set previousPost = collections.posts | getPreviousCollectionItem %}
{%- set nextPost = collections.posts | getNextCollectionItem %}
{%- if nextPost or previousPost %}
<ul class="links-nextprev">
	{%- if previousPost %}<li>Previous: <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a></li>{% endif %}
	{%- if nextPost %}<li>Next: <a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a></li>{% endif %}
</ul>
{%- endif %}
{%- endif %}
