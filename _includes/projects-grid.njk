<ul class="projects-list">
  {% for project in collections.projects | reverse %}
    <li class="project-list-item">
      <a href="{{ project.url }}" class="project-list-title">{{ project.data.title }}</a>
      {% if project.data.byline %}
        <div class="project-list-byline">{{ project.data.byline }}</div>
      {% endif %}
    </li>
  {% endfor %}
</ul>
